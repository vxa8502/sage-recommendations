# Sage RAG Recommendation System - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Provider (required)
# =============================================================================
LLM_PROVIDER=anthropic              # or "openai"
ANTHROPIC_API_KEY=your_anthropic_api_key
# OPENAI_API_KEY=your_openai_api_key

# =============================================================================
# Qdrant Vector Database
# =============================================================================
# Hosted Qdrant cluster (required)
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key

# =============================================================================
# Security
# =============================================================================
# CORS_ORIGINS=https://your-domain.com,http://localhost:3000  # Comma-separated
# CACHE_ADMIN_TOKEN=your_secret_token  # Required to call POST /cache/clear; unset = no auth

# =============================================================================
# Optional
# =============================================================================
# HF_TOKEN=your_huggingface_token   # For private models
# PORT=8000                          # Render/Railway inject automatically

# =============================================================================
# Data Ingestion (Kaggle / ESCI)
# =============================================================================
# GitHub CLI auth is optional for the public ESCI repo, but supported:
# GH_TOKEN=your_github_token
#
# Kaggle CLI auth can use either:
# KAGGLE_API_TOKEN=your_kaggle_api_token
# or the older pair:
# KAGGLE_USERNAME=your_kaggle_username
# KAGGLE_KEY=your_kaggle_key
#
# Kaggle kernel ref used by `sage stage data ...`
SAGE_KAGGLE_KERNEL=your-kaggle-username/sage-stage-data
# Optional override for the kernel title shown on Kaggle:
# SAGE_KAGGLE_KERNEL_TITLE=Sage Stage Data
#
# Kaggle package dataset attached to the ingestion kernel. Keep your one-time
# Qdrant secrets configured in the Kaggle UI for that kernel.
SAGE_KAGGLE_PACKAGE_DATASET=stardewcvalley/sage-package
# Compatibility hint only. Any non-empty value enables GPU in kernel metadata;
# Kaggle decides the exact machine shape at runtime.
# SAGE_KAGGLE_ACCELERATOR=NvidiaTeslaT4
